generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Asset {
  id                String  @id
  name              String
  availableQuantity Int
  totalQuantity     Int
  Location          String?
  category          String?
  logs              Log[]

  @@index([name])
}

model Log {
  id             String    @id @default(uuid())
  assetId        String
  action         Action
  issuedBy       String
  issuedTo       String
  emailAddress   String
  notes          String?
  createdAt      DateTime  @default(now())
  reminderSentAt DateTime?
  escalatedAt    DateTime?
  asset          Asset     @relation(fields: [assetId], references: [id])
}

enum Action {
  CHECK_OUT
  CHECK_IN
}
